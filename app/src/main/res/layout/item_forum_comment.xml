<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingVertical="10dp"
    android:paddingHorizontal="12dp"
    android:background="?android:attr/selectableItemBackground">

    <!-- Reply Indent Line -->
    <View
        android:id="@+id/viewReplyIndicator"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_reply_line"
        android:visibility="gone"
        tools:visibility="visible" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Comment Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Avatar -->
            <androidx.cardview.widget.CardView
                android:layout_width="32dp"
                android:layout_height="32dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:background="@color/mulberry_light_transparent">

                <ImageView
                    android:id="@+id/ivCommentAuthorAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/ic_user_avatar"
                    android:contentDescription="Author avatar"
                    android:padding="6dp"
                    android:tint="@color/mulberry" />
            </androidx.cardview.widget.CardView>

            <!-- Author Name & Expert Badge -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvCommentAuthorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:clickable="true"
                        tools:text="Lakshmi Devi" />

                    <ImageView
                        android:id="@+id/viewExpertBadge"
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:layout_marginStart="4dp"
                        android:src="@drawable/ic_expert_badge"
                        android:visibility="gone"
                        tools:visibility="visible" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvCommentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    tools:text="1 hour ago" />
            </LinearLayout>

            <!-- Like Button -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/btnCommentLike"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_thumb_up_outline"
                    android:contentDescription="Like"
                    android:padding="4dp" />

                <TextView
                    android:id="@+id/tvCommentLikeCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    tools:text="5" />
            </LinearLayout>
        </LinearLayout>

        <!-- Comment Text -->
        <TextView
            android:id="@+id/tvCommentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="40dp"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:lineSpacingExtra="3dp"
            tools:text="This is a very helpful tip! I tried spreading wet gunny bags and the temperature dropped by 2 degrees within an hour. Highly recommended for all farmers." />

        <!-- Reply & Delete Buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="36dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnCommentReply"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_reply_outline"
                android:contentDescription="Reply"
                android:padding="4dp" />

            <TextView
                android:id="@+id/tvReplyCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/mulberry"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true"
                android:paddingHorizontal="4dp"
                tools:text="3 replies" />

            <ImageButton
                android:id="@+id/btnCommentDelete"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="12dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_delete_outline"
                android:contentDescription="Delete"
                android:visibility="gone"
                android:padding="4dp"
                android:tint="@color/danger_red"
                tools:visibility="visible" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>